{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client"],

    "noEmit": true,
    "isolatedModules": true,
    "sourceMap": true,

    "useDefineForClassFields": true,
    "noUncheckedSideEffectImports": true,

    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["src", "vite.config.ts"]
}
